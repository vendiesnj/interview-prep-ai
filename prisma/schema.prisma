generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
}

model User {
  id                   String               @id @default(cuid())
  email                String?              @unique
  passwordHash         String?
  name                 String?
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt
  emailVerified        DateTime?
  image                String?
  currentPeriodEnd     DateTime?
  stripeCustomerId     String?              @unique
  stripePriceId        String?
  stripeSubscriptionId String?              @unique
  subscriptionStatus   String?
  freeAttemptCap       Int                  @default(3)
  freeAttemptsUsed     Int                  @default(0)
  tenantId             String?
  demoPersona          String?
  // Career profile fields
  graduationYear       Int?
  major                String?
  targetRole           String?
  targetIndustry       String?
  accounts             Account[]
  attempts             Attempt[]
  jobProfiles          JobProfile[]
  passwordResetTokens  PasswordResetToken[]
  sessions             Session[]
  memberships          TenantMembership[]
  tenant               Tenant?              @relation("UserHomeTenant", fields: [tenantId], references: [id])
  careerCheckIns       CareerCheckIn[]
  aptitudeResults      AptitudeResult[]
  checklistProgress    ChecklistProgress[]
  interviewActivities  InterviewActivity[]
  studentSkills        StudentSkill[]
  resumeAnalyses       ResumeAnalysis[]
  instinctSessions     InstinctSession[]
  browserSessions      BrowserSession[]   @relation("BrowserSessions")
  tasks                Task[]

  @@index([stripeCustomerId])
  @@index([stripeSubscriptionId])
  @@index([tenantId])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Attempt {
  id                  String    @id @default(cuid())
  userId              String
  ts                  DateTime  @default(now())
  question            String
  transcript          String
  inputMethod         String?
  prosody             Json?
  feedback            Json?
  score               Float?
  communicationScore  Float?
  confidenceScore     Float?
  jobDesc             String?
  focusGoal           String?
  audioId             String?
  durationSeconds     Int?
  wpm                 Int?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  deletedAt           DateTime?
  deliveryMetrics     Json?
  audioPath           String?
  audioMime           String?
  audioUrl            String?
  jobProfileCompany   String?
  jobProfileId        String?
  jobProfileRoleType  String?
  jobProfileTitle     String?
  questionCategory    String?
  questionSource      String?
  evaluationFramework String?
  tenantId            String?
  tenant              Tenant?   @relation("TenantAttempts", fields: [tenantId], references: [id])
  user                User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([jobProfileId])
  @@index([userId, createdAt])
  @@index([userId, deletedAt, createdAt])
  @@index([userId, deletedAt])
  @@index([userId, deletedAt, ts(sort: Desc)])
  @@index([tenantId, userId, deletedAt, ts(sort: Desc)])
}

model Tenant {
  id             String             @id @default(cuid())
  name           String
  slug           String             @unique
  plan           String             @default("university")
  themeKey       String             @default("default")
  emailDomains   String[]           @default([])
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  accent         String?
  accent2        String?
  accent2Soft    String?
  accentSoft     String?
  accentStrong   String?
  cardBg         String?
  cardBgStrong   String?
  cardBorder     String?
  cardBorderSoft String?
  danger         String?
  dangerSoft     String?
  inputBg        String?
  inputBorder    String?
  logoUrl        String?
  pageBg         String?
  pageBgAccentA  String?
  pageBgAccentB  String?
  success        String?
  successSoft    String?
  textMuted      String?
  textPrimary    String?
  textSoft       String?
  attempts       Attempt[]          @relation("TenantAttempts")
  assignments    Assignment[]
  jobProfiles    JobProfile[]
  memberships    TenantMembership[]
  users          User[]             @relation("UserHomeTenant")
}

model TenantMembership {
  id        String           @id @default(cuid())
  tenantId  String
  userId    String
  role      TenantRole       @default(student)
  status    MembershipStatus @default(active)
  isDefault Boolean          @default(true)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  tenant    Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tenantId, userId])
  @@index([userId, status])
  @@index([tenantId, role, status])
  @@index([tenantId, isDefault])
}

model JobProfile {
  id                String    @id @default(cuid())
  tenantId          String
  userId            String
  title             String
  company           String?
  roleType          String?
  jobDescription    String
  competencyWeights Json?
  targetTraits      Json?
  isArchived        Boolean   @default(false)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  deletedAt         DateTime?
  tenant            Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tenantId, userId, isArchived])
  @@index([userId, createdAt])
  @@index([tenantId, title])
}

model Assignment {
  id                  String    @id @default(cuid())
  tenantId            String
  createdByUserId     String
  title               String
  description         String?
  dueDate             DateTime?
  questionCategories  String[]  @default([])
  evaluationFramework String?
  minAttempts         Int       @default(5)
  isActive            Boolean   @default(true)
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  tenant              Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, isActive])
  @@index([tenantId, createdAt])
}

model StripeEvent {
  id        String   @id
  createdAt DateTime @default(now())
}

model AuditLog {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  userId    String?
  action    String
  meta      Json?
  ip        String?
  userAgent String?

  @@index([userId, createdAt])
  @@index([action, createdAt])
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([expiresAt])
}

model CareerCheckIn {
  id               String   @id @default(cuid())
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  userId           String
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenantId         String?

  // Employment status
  employmentStatus String   // "employed", "job_searching", "graduate_school", "freelance", "other"
  jobTitle         String?
  company          String?
  industry         String?
  city             String?
  state            String?

  // Compensation (range bands + optional exact value)
  salaryRange      String?  // "under_40k", "40_50k", "50_60k", "60_75k", "75_90k", "90_110k", "110_130k", "over_130k"
  salaryExact      Int?     // exact annual salary in dollars (optional)

  // Demographics
  age              Int?     // self-reported age

  // Career context
  graduationYear   Int?
  major            String?
  monthsSinceGrad  Int?     // computed at submit time

  // Satisfaction
  satisfactionScore Int?    // 1–5
  topChallenge     String?  // "salary", "growth", "work_life", "culture", "skills_gap", "other"

  // Housing & financial
  monthlyRent         Int?     // actual monthly housing cost in dollars
  has401k             Boolean?
  contribution401kPct Int?     // e.g. 6 = 6%
  currentSavingsRange String?  // "under_5k", "5_15k", "15_30k", "30_60k", "60_100k", "over_100k"
  currentSavingsExact Int?     // exact savings amount in dollars (optional)
  studentLoanRange    String?  // "none", "under_10k", "10_30k", "30_60k", "60_100k", "over_100k"
  studentLoanExact    Int?     // exact loan balance in dollars (optional)
  retirementGoalAge   Int?     // e.g. 55, 60, 65

  // Other retirement & savings
  hasRothIRA              Boolean?
  rothIRAMonthly          Int?     // monthly Roth IRA contribution in dollars
  hasHSA                  Boolean?
  hsaMonthly              Int?     // monthly HSA contribution in dollars
  emergencyFundMonths     String?  // "none", "1_2", "3_6", "6_plus"
  additionalSavingsMonthly Int?    // other monthly savings (brokerage, HYSA, etc.)

  // University feedback
  universitySatisfaction     Int?     // 1–5
  wouldChooseSameUniversity  Boolean?
  universityName             String?

  // Progress checklist (JSON array of completed item keys)
  checklistItems   Json?

  @@index([userId])
  @@index([tenantId])
  @@index([createdAt])
}

model ChecklistProgress {
  id            String    @id @default(cuid())
  userId        String
  tenantId      String?
  stage         String    // "pre_college" | "during_college" | "post_college"
  itemId        String    // matches hardcoded checklist item id
  done          Boolean   @default(true)
  scheduledDate DateTime? // user-chosen target date
  updatedAt     DateTime  @updatedAt
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, stage, itemId])
  @@index([userId, stage])
  @@index([tenantId, stage])
}

model ChecklistItemContent {
  id          String   @id @default(cuid())
  tenantId    String
  stage       String
  itemId      String
  body        String   // admin-editable rich description
  linkHref    String?
  linkLabel   String?
  updatedAt   DateTime @updatedAt

  @@unique([tenantId, stage, itemId])
  @@index([tenantId, stage])
}

model AptitudeResult {
  id        String   @id @default(cuid())
  userId    String
  tenantId  String?
  createdAt DateTime @default(now())
  primary   String
  secondary String
  scores    Json
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([tenantId])
}

model ResumeAnalysis {
  id              String   @id @default(cuid())
  userId          String
  tenantId        String?
  createdAt       DateTime @default(now())
  overallScore    Int
  atsScore        Int
  overallLabel    String
  summary         String
  topAction       String
  gaps            Json     // { category, issue, fix }[]
  strengths       Json     // string[]
  keywordsPresent Json     // string[]
  keywordsMissing Json     // string[]
  resumeSnippet   String?  // first 400 chars for reference display
  jobDescSnippet  String?  // first 200 chars of JD if provided
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([tenantId])
}

model InterviewActivity {
  id            String    @id @default(cuid())
  userId        String
  tenantId      String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  company       String
  role          String
  industry      String?
  appliedDate   DateTime?
  interviewDate DateTime?
  // "applied" | "phone_screen" | "technical" | "on_site" | "final_round" | "offer" | "rejected" | "accepted" | "declined"
  stage         String    @default("applied")
  outcome       String?   // "pending" | "rejected" | "offer_received" | "accepted" | "declined"
  salaryOffered Int?      // annual, in dollars
  notes         String?
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([tenantId, createdAt])
}

model StudentSkill {
  id         String   @id @default(cuid())
  userId     String
  tenantId   String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  skill      String
  category   String   // "technical" | "communication" | "leadership" | "analytical" | "interpersonal" | "domain"
  confidence Float    @default(0.7) // 0–1, AI confidence
  source     String   @default("ai_extracted") // "ai_extracted" | "self_reported"
  attemptIds String[] @default([])
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, skill])
  @@index([userId])
  @@index([tenantId])
}

model InstinctSession {
  id              String   @id @default(cuid())
  userId          String
  tenantId        String?
  createdAt       DateTime @default(now())
  scenariosPlayed String[] @default([])
  responses       Json     // Array<{ scenarioId, choiceIndex }>
  dimensions      Json     // { teamwork, leadership, communication, criticalThinking, professionalism, adaptability }
  xpEarned        Int      @default(0)
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([tenantId])
}

model BrowserSession {
  id           String              @id @default(cuid())
  studentId    String
  startedAt    DateTime            @default(now())
  endedAt      DateTime?
  totalSeconds Int                 @default(0)
  isActive     Boolean             @default(true)
  urlVisits    UrlVisit[]
  screenshots  BrowserScreenshot[]
  taskEvents   BrowserTaskEvent[]
  student      User                @relation("BrowserSessions", fields: [studentId], references: [id])
}

model UrlVisit {
  id            String         @id @default(cuid())
  sessionId     String
  url           String
  title         String?
  domain        String
  enteredAt     DateTime       @default(now())
  exitedAt      DateTime?
  activeSeconds Int            @default(0)
  session       BrowserSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
}

model BrowserScreenshot {
  id        String         @id @default(cuid())
  sessionId String
  url       String
  takenAt   DateTime       @default(now())
  imageData String         @db.Text
  session   BrowserSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
}

model BrowserTaskEvent {
  id          String         @id @default(cuid())
  sessionId   String
  taskId      String
  activeUrl   String
  completedAt DateTime       @default(now())
  session     BrowserSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
}

model Task {
  id          String    @id @default(cuid())
  userId      String
  tenantId    String?
  title       String
  notes       String?
  priority    String    @default("medium") // "high" | "medium" | "low"
  category    String?
  dueDate     DateTime?
  scheduledAt DateTime? // date+time placed on calendar
  completedAt DateTime? // when the user checked it off
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, completedAt])
  @@index([userId, dueDate])
  @@index([tenantId])
}

enum TenantRole {
  student
  tenant_admin
  career_coach
  super_admin
}

enum MembershipStatus {
  active
  invited
  disabled
}
