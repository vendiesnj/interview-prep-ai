generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                   String    @id @default(cuid())
  email                String?   @unique
  passwordHash         String?
  name                 String?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
  emailVerified        DateTime?
  image                String?
  currentPeriodEnd     DateTime?
  stripeCustomerId     String?   @unique
  stripePriceId        String?
  stripeSubscriptionId String?   @unique
  subscriptionStatus   String?
  freeAttemptCap       Int       @default(3)
  freeAttemptsUsed     Int       @default(0)
  accounts             Account[]
  attempts             Attempt[]
  sessions             Session[]

  @@index([stripeCustomerId])
  @@index([stripeSubscriptionId])

  passwordResetTokens PasswordResetToken[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Attempt {
  id                 String    @id @default(cuid())
  userId             String
  ts                 DateTime  @default(now())
  question           String
  transcript         String
  inputMethod        String?
  prosody            Json?
  deliveryMetrics    Json?
  feedback           Json?
  score              Float?
  communicationScore Float?
  confidenceScore    Float?
  jobDesc            String?
  focusGoal          String?
  audioId            String?
  durationSeconds    Int?
  wpm                Int?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  deletedAt          DateTime?
  user               User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  audioUrl           String? 
  audioMime          String?
  audioPath          String?
  jobProfileId       String?
  jobProfileTitle    String?
  jobProfileCompany  String?
  jobProfileRoleType String?
  questionCategory   String?
  questionSource     String?
  evaluationFramework String?

  @@index([userId, createdAt])
  @@index([userId, deletedAt, createdAt])
  @@index([userId, deletedAt])
  @@index([userId, deletedAt, ts(sort: Desc)])
}

model StripeEvent {
  id        String   @id
  createdAt DateTime @default(now())
}

model AuditLog {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  userId    String?
  action    String
  meta      Json?
  ip        String?
  userAgent String?

  @@index([userId, createdAt])
  @@index([action, createdAt])
}

model PasswordResetToken {
  id            String   @id @default(cuid())
  userId        String
  tokenHash     String   @unique
  expiresAt     DateTime
  usedAt        DateTime?
  createdAt     DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([expiresAt])
}
