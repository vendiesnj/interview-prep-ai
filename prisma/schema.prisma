generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum TenantRole {
  student
  tenant_admin
  career_coach
  super_admin
}

enum MembershipStatus {
  active
  invited
  disabled
}

model User {
  id                   String    @id @default(cuid())
  email                String?   @unique
  passwordHash         String?
  name                 String?
  demoPersona          String?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
  emailVerified        DateTime?
  image                String?
  currentPeriodEnd     DateTime?
  stripeCustomerId     String?   @unique
  stripePriceId        String?
  stripeSubscriptionId String?   @unique
  subscriptionStatus   String?
  freeAttemptCap       Int       @default(3)
  freeAttemptsUsed     Int       @default(0)

  // Transitional: keep this so your current auth/routes continue to work
  tenantId             String?
  tenant               Tenant?   @relation("UserHomeTenant", fields: [tenantId], references: [id], onDelete: SetNull)

  accounts             Account[]
  attempts             Attempt[]
  sessions             Session[]

  // New robust multi-tenant model
  memberships          TenantMembership[]
  jobProfiles          JobProfile[]

  passwordResetTokens  PasswordResetToken[]

  @@index([stripeCustomerId])
  @@index([stripeSubscriptionId])
  @@index([tenantId])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Attempt {
  id                  String    @id @default(cuid())
  userId              String
  tenantId            String?
  ts                  DateTime  @default(now())
  question            String
  transcript          String
  inputMethod         String?
  prosody             Json?
  deliveryMetrics     Json?
  feedback            Json?
  score               Float?
  communicationScore  Float?
  confidenceScore     Float?
  jobDesc             String?
  focusGoal           String?
  audioId             String?
  durationSeconds     Int?
  wpm                 Int?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  deletedAt           DateTime?

  user                User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant              Tenant?   @relation("TenantAttempts", fields: [tenantId], references: [id], onDelete: SetNull)

  audioUrl            String?
  audioMime           String?
  audioPath           String?

    // Transitional: keep as loose string for now.
  // Existing attempts already contain legacy/local profile ids.
  // We will convert this to a true FK after backfilling DB job profiles.
  jobProfileId        String?
  jobProfileTitle     String?
  jobProfileCompany   String?
  jobProfileRoleType  String?

  questionCategory    String?
  questionSource      String?
  evaluationFramework String?

  @@index([tenantId])
  @@index([jobProfileId])
  @@index([userId, createdAt])
  @@index([userId, deletedAt, createdAt])
  @@index([userId, deletedAt])
  @@index([userId, deletedAt, ts(sort: Desc)])
  @@index([tenantId, userId, deletedAt, ts(sort: Desc)])
}

model Tenant {
  id              String    @id @default(cuid())
  name            String
  slug            String    @unique
  themeKey        String    @default("default")
  emailDomains    String[]  @default([])

  pageBg          String?
  pageBgAccentA   String?
  pageBgAccentB   String?

  textPrimary     String?
  textMuted       String?
  textSoft        String?

  cardBg          String?
  cardBgStrong    String?
  cardBorder      String?
  cardBorderSoft  String?

  inputBg         String?
  inputBorder     String?

  accent          String?
  accentSoft      String?
  accentStrong    String?

  accent2         String?
  accent2Soft     String?

  danger          String?
  dangerSoft      String?

  success         String?
  successSoft     String?

  logoUrl         String?

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  // Existing relations
  users           User[]    @relation("UserHomeTenant")
  attempts        Attempt[] @relation("TenantAttempts")

  // New robust relations
  memberships     TenantMembership[]
  jobProfiles     JobProfile[]
}

model TenantMembership {
  id         String           @id @default(cuid())
  tenantId   String
  userId     String
  role       TenantRole       @default(student)
  status     MembershipStatus @default(active)
  isDefault  Boolean          @default(true)
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt

  tenant     Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user       User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tenantId, userId])
  @@index([userId, status])
  @@index([tenantId, role, status])
  @@index([tenantId, isDefault])
}

model JobProfile {
  id                String    @id @default(cuid())
  tenantId          String
  userId            String

  title             String
  company           String?
  roleType          String?
  jobDescription    String

  // Future-proofing for role-aware scoring / competencies
  competencyWeights Json?
  targetTraits      Json?

  isArchived        Boolean   @default(false)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  deletedAt         DateTime?

  tenant            Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  

  @@index([tenantId, userId, isArchived])
  @@index([userId, createdAt])
  @@index([tenantId, title])
}

model StripeEvent {
  id        String   @id
  createdAt DateTime @default(now())
}

model AuditLog {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  userId    String?
  action    String
  meta      Json?
  ip        String?
  userAgent String?

  @@index([userId, createdAt])
  @@index([action, createdAt])
}

model PasswordResetToken {
  id            String   @id @default(cuid())
  userId        String
  tokenHash     String   @unique
  expiresAt     DateTime
  usedAt        DateTime?
  createdAt     DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([expiresAt])
}
